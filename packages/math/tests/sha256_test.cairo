use alexandria_math::sha256;
use snforge_std::*;

#[test]
fn sha256_empty_test() {
    let mut input: Array<u8> = array![];
    let result = sha256::sha256(input);

    // result should be 0xE3B0C44298FC1C149AFBF4C8996FB92427AE41E4649B934CA495991B7852B855
    assert(result.len() == 32, 'assertion failed');
    assert(*result[0] == 0xE3, 'assertion failed');
    assert(*result[1] == 0xB0, 'assertion failed');
    assert(*result[2] == 0xC4, 'assertion failed');
    assert(*result[3] == 0x42, 'assertion failed');
