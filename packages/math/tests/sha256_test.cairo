#[test]
fn sha256_random_data_test() {
    let mut input: Array<u8> = array![
        0x57, 0x77, 0x71, 0x71, 0x66, 0x50, 0x45, 0x51, 0x51, 0x43, 0x39, 0x48, 0x38,
    ];
    let result = sha256::sha256(input);
    assert(*result[0] == 61, 'assertion failed');
