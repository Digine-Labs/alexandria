#[test]
fn sha256_url() {
    let data = array![
        '{', '"', 't', 'y', 'p', 'e', '"', ':', '"', 'w', 'e', 'b', 'a', 'u', 't', 'h', 'n', '.',
        'g', 'e', 't', '"', ',', '"', 'c', 'h', 'a', 'l', 'l', 'e', 'n', 'g', 'e', '"', ':', '"',
